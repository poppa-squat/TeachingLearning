# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/

# Runtime data (the user's map, its history, the embedding cache, cost log).
# By default these live in the per-user data dir (see app/paths.py), but they
# land here if TEACHINGLEARNING_DATA_DIR points at the project during dev.
# Local secrets / config — the DeepSeek API key lives here, never commit it.
# .env.example IS committed as a template (see the ! rule below).
.env
!.env.example

# Runtime data (the user's map, its history, and the embedding cache)
graph.json
snapshots/
embeddings_cache.npz
llm_costs.log

# Note: ui/vendor/ IS committed — the app must work offline.
