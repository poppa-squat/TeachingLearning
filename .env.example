# Copy this file to `.env` and fill in your values. `.env` is git-ignored, so
# your API key stays out of version control. Loaded automatically at startup
# (main.py); already-exported shell env vars take precedence over this file.

# Which generative provider to use: "ollama" (local, default) or "deepseek".
LLM_PROVIDER=deepseek

# Required when LLM_PROVIDER=deepseek. Get one at https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-...

# --- Optional overrides (sensible defaults live in app/llm.py) ---
# DEEPSEEK_MODEL=deepseek-v4-pro
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3:4b
